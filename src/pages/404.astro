---
import Base from "../layouts/Base.astro";
---

<Base title="404 — Page not found · hefker.dev" path="/404">
  <section class="py-12 sm:py-20">
    <p class="text-sm uppercase tracking-widest text-base-content/60">404</p>
    <h1 class="mt-4 text-4xl sm:text-5xl font-medium tracking-tight">
      Page not found
    </h1>
    <p class="mt-6 text-base-content/80">
      That path doesn't exist on hefker.dev. It may have moved or never been
      here at all.
    </p>
    <p class="mt-8">
      <a href="/" class="link link-hover underline underline-offset-4">
        ← Back home
      </a>
    </p>
  </section>
</Base>

---
const links = [
  {
    href: "https://github.com/HefKer",
    label: "GitHub",
    external: true,
    icon: "github",
  },
  {
    href: "https://www.linkedin.com/in/nelson-j-aviles/",
    label: "LinkedIn",
    external: true,
    icon: "linkedin",
  },
  {
    href: "mailto:nelson@hefker.dev",
    label: "Email",
    external: false,
    icon: "mail",
  },
] as const;
---

<section class="hero-section">
  <h1 class="text-4xl sm:text-5xl font-medium tracking-tight">Nelson Aviles</h1>
  <p class="mt-3 text-lg text-base-content/80">
    Computer Science student &amp; developer based in Houston
  </p>
  <p class="mt-6 text-base-content/85">
    CS Student at Houston City College (4.0 GPA), aiming at backend and
    full-stack junior developer roles. Builds backend services, Linux tooling,
    and small utilities with Python, Nix, and Astro. Vice President of HCC's
    Computer Science Association and Director of Logistics for the HackHCC:
    Coderunners hackathon.
  </p>
  <ul class="mt-6 flex flex-wrap gap-x-5 gap-y-2 text-sm">
    {
      links.map((l) => (
        <li>
          <a
            href={l.href}
            class="inline-flex items-center gap-1.5 link link-hover"
            {...l.external
              ? { target: "_blank", rel: "noopener noreferrer" }
              : {}}
          >
            {l.icon === "github" && (
              <svg
                aria-hidden="true"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path d="M12 .5a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2.2c-3.3.7-4-1.6-4-1.6-.5-1.3-1.3-1.6-1.3-1.6-1.1-.8.1-.8.1-.8 1.2.1 1.9 1.3 1.9 1.3 1.1 1.9 2.9 1.3 3.6 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.3-3.2-.1-.3-.6-1.6.1-3.3 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0c2.3-1.5 3.3-1.2 3.3-1.2.7 1.7.2 3 .1 3.3.8.8 1.3 1.9 1.3 3.2 0 4.7-2.8 5.7-5.5 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .5Z" />
              </svg>
            )}
            {l.icon === "linkedin" && (
              <svg
                aria-hidden="true"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path d="M20.5 2h-17A1.5 1.5 0 0 0 2 3.5v17A1.5 1.5 0 0 0 3.5 22h17a1.5 1.5 0 0 0 1.5-1.5v-17A1.5 1.5 0 0 0 20.5 2ZM8 19H5V9h3v10ZM6.5 7.7a1.7 1.7 0 1 1 0-3.4 1.7 1.7 0 0 1 0 3.4ZM19 19h-3v-5.2c0-1.2 0-2.8-1.7-2.8s-2 1.3-2 2.7V19h-3V9h2.9v1.4h.1a3.2 3.2 0 0 1 2.9-1.6c3.1 0 3.7 2 3.7 4.7V19Z" />
              </svg>
            )}
            {l.icon === "mail" && (
              <svg
                aria-hidden="true"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="3" y="5" width="18" height="14" rx="2" />
                <path d="m3 7 9 6 9-6" />
              </svg>
            )}
            <span>{l.label}</span>
          </a>
        </li>
      ))
    }
  </ul>
</section>

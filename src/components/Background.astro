---
// Fixed ambient layer: soft vertical gradient + dot-grid.
// Sits behind everything via z-index: -1, pinned to viewport so iOS doesn't jitter on scroll.
---

<div class="bg-layer" aria-hidden="true">
  <div class="bg-dots"></div>
</div>

<style>
  .bg-layer {
    position: fixed;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      to bottom,
      var(--color-base-100) 0%,
      var(--color-base-200) 100%
    );
    pointer-events: none;
  }

  .bg-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      circle,
      var(--color-base-content) 1px,
      transparent 1px
    );
    background-size: 24px 24px;
    opacity: 0.06;
  }

  @media (prefers-color-scheme: dark) {
    .bg-dots {
      opacity: 0.08;
    }
  }
</style>
